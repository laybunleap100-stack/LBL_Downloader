@{ Layout = null; }
<!DOCTYPE html>
<html lang="km">
<head>
    <meta charset="UTF-8">
    <title>LBL Downloader - ទាញយកវីដេអូ</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Kantumruy+Pro:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Kantumruy Pro', sans-serif; background-color: #f4f7f6; padding-top: 50px; }
        .card { border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); border: none; }
        .btn-download { background-color: #007bff; color: white; font-weight: bold; padding: 12px; border-radius: 10px; }
        .btn-download:hover { background-color: #0056b3; }
        .progress { height: 25px; border-radius: 10px; display: none; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card p-5">
                    <h2 class="text-center text-primary mb-4">ទាញយក LBL</h2>

                    <div class="mb-4">
                        <label class="form-label">តំណភ្ជាប់វីដេអូ (Video URL)</label>
                        <input type="text" id="videoUrl" class="form-control" placeholder="https://...">
                    </div>

                    <button id="btnAction" onclick="handleDownload()" class="btn btn-download w-100">
                        ទាញយក
                    </button>

                    <div class="progress mt-4" id="progressContainer">
                        <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                             role="progressbar" style="width: 0%;">0%</div>
                    </div>

                    <div id="result" class="mt-4 text-center"></div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/downloadHub")
            .build();

        connection.start().catch(err => console.error("SignalR error:", err));

        connection.on("ReceiveProgress", function (percent) {
            document.getElementById('progressContainer').style.display = "flex";
            const bar = document.getElementById('progressBar');
            bar.style.width = percent + "%";
            bar.innerText = percent + "%";
        });

        async function handleDownload() {
            const url = document.getElementById('videoUrl').value.trim();
            const btn = document.getElementById('btnAction');
            const resultDiv = document.getElementById('result');
            const bar = document.getElementById('progressBar');

            if (!url) { alert("សូមបញ្ចូល URL!"); return; }

            btn.disabled = true;
            document.getElementById('progressContainer').style.display = "flex";
            bar.style.width = "0%";
            bar.innerText = "0%";
            resultDiv.innerHTML = "";

            try {
        
                const response = await fetch('/Download/StartDownload', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'videoUrl=' + encodeURIComponent(url)
                });

                const data = await response.json();

                if (data.success) {
              
                    resultDiv.innerHTML = `
                        <div class="alert alert-success">
                            ទាញយកបានជោគជ័យ! <br>
                            <a href="/Download/GetFile?fileName=${encodeURIComponent(data.fileName)}"
                               class="btn btn-success mt-2 fw-bold text-decoration-none">
                                💾 រក្សាទុកវីដេអូ
                            </a>
                        </div>`;
              
                    bar.style.width = "100%";
                    bar.innerText = "100%";
                } else {
                    resultDiv.innerHTML = `<div class="alert alert-danger">កំហុស: ${data.message}</div>`;
                }
            } catch (err) {
                resultDiv.innerHTML = `<div class="alert alert-danger">កំហុសបណ្តាញ: ${err.message}</div>`;
            } finally {
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
